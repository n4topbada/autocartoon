generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CharacterGroup {
  id        String   @id @default(cuid())
  name      String
  userId    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?             @relation(fields: [userId], references: [id])
  presets CharacterPreset[]

  @@index([userId, order])
}

model CharacterPreset {
  id                    String   @id @default(cuid())
  alias                 String   @unique
  name                  String
  userId                String?
  price                 Int      @default(0)
  isPublic              Boolean  @default(false)
  groupId               String?
  representativeImageId String?
  description           String?  @db.Text
  persona               Json?
  voiceConfig           Json?
  isDefault             Boolean  @default(false)
  order                 Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user               User?               @relation(fields: [userId], references: [id])
  group              CharacterGroup?     @relation(fields: [groupId], references: [id])
  images             PresetImage[]
  generationRequests GenerationRequest[]
  purchasedBy        PurchasedPreset[]

  @@index([userId, order])
  @@index([userId, isDefault])
  @@index([groupId, order])
  @@index([isPublic, groupId, createdAt])
}

model PurchasedPreset {
  id        String   @id @default(cuid())
  userId    String
  presetId  String
  createdAt DateTime @default(now())

  user   User            @relation(fields: [userId], references: [id])
  preset CharacterPreset @relation(fields: [presetId], references: [id])

  @@unique([userId, presetId])
}

model PresetImage {
  id           String   @id @default(cuid())
  presetId     String
  blobUrl      String // Vercel Blob URL
  thumbnailUrl String?
  mimeType     String   @default("image/png")
  view         String   @default("reference")
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  preset CharacterPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@index([presetId, view, order])
}

model SavedBackground {
  id           String   @id @default(cuid())
  name         String
  blobUrl      String // Vercel Blob URL
  thumbnailUrl String?
  mimeType     String   @default("image/png")
  userId       String?
  createdAt    DateTime @default(now())

  user               User?               @relation(fields: [userId], references: [id])
  generationRequests GenerationRequest[]

  @@index([userId, createdAt])
}

model GenerationRequest {
  id                String   @id @default(cuid())
  presetId          String?
  presetIds         String[] // 다중 캐릭터 선택
  userId            String?
  mode              String // "text" | "sketch" | "edit"
  prompt            String
  background        String? // 텍스트 배경 이름
  backgroundImageId String? // 저장된 배경 이미지 FK
  jobId             String?  @unique
  createdAt         DateTime @default(now())

  user            User?            @relation(fields: [userId], references: [id])
  preset          CharacterPreset? @relation(fields: [presetId], references: [id])
  backgroundImage SavedBackground? @relation(fields: [backgroundImageId], references: [id])
  job             GenerationJob?   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  generatedImages GeneratedImage[]

  @@index([userId, createdAt])
}

model User {
  id                         String    @id @default(cuid())
  email                      String    @unique
  kakaoId                    String?   @unique
  passwordHash               String
  name                       String?
  role                       String    @default("user")
  tier                       String    @default("free")
  credits                    Int       @default(0)
  tierUsedThisMonth          Int       @default(0)
  tierResetAt                DateTime  @default(now())
  emailVerified              Boolean   @default(false)
  verifyToken                String?   @unique
  verifyTokenExp             DateTime?
  temporaryPasswordHash      String?
  temporaryPasswordExpiresAt DateTime?
  temporaryPasswordIssuedAt  DateTime?
  passwordChangedAt          DateTime?
  welcomeCreditsGrantedAt    DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  presets            CharacterPreset[]
  characterGroups    CharacterGroup[]
  backgrounds        SavedBackground[]
  generationRequests GenerationRequest[]
  purchasedPresets   PurchasedPreset[]
  boardPosts         BoardPost[]
  boardComments      BoardComment[]
  boardLikes         BoardLike[]
  helpRequests       HelpRequest[]
  imageTags          ImageTag[]
  instagramAccount   InstagramAccount?
  promptPresets      PromptPreset[]
  contents           Content[]
  generationJobs     GenerationJob[]
  creditLedger       CreditLedger[]
  creditPayments     CreditPayment[]
  creativeProjects   CreativeProject[]
  savedProjectBriefs SavedProjectBrief[]
  sessions           UserSession[]
}

model UserSession {
  id         String   @id @default(cuid())
  userId     String
  device     String
  userAgent  String   @db.Text
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lastSeenAt])
  @@index([expiresAt])
}

model GenerationJob {
  id                     String    @id @default(cuid())
  userId                 String
  projectId              String?
  cutId                  String?
  kind                   String
  status                 String    @default("queued")
  stage                  String    @default("queued")
  progress               Int       @default(0)
  provider               String
  model                  String
  idempotencyKey         String
  prompt                 String    @db.Text
  input                  Json
  output                 Json?
  error                  String?   @db.Text
  runId                  String?   @unique
  operationName          String?
  creditSource           String?
  creditUnits            Int?
  estimatedCostUsdMicros Int?
  startedAt              DateTime?
  completedAt            DateTime?
  notifiedAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       CreativeProject?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  cut           ProjectCut?          @relation(fields: [cutId], references: [id], onDelete: SetNull)
  request       GenerationRequest?
  artifacts     GenerationArtifact[]
  creditEntries CreditLedger[]
  projectAssets ProjectAsset[]

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([userId, kind, createdAt])
  @@index([userId, status, updatedAt])
  @@index([userId, status, completedAt])
  @@index([projectId, createdAt])
  @@index([cutId, createdAt])
}

model GenerationArtifact {
  id           String   @id @default(cuid())
  jobId        String
  kind         String
  blobUrl      String
  thumbnailUrl String?
  mimeType     String
  metadata     Json?
  createdAt    DateTime @default(now())

  job GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model CreditLedger {
  id           String   @id @default(cuid())
  userId       String
  jobId        String?
  referenceKey String   @unique
  action       String
  source       String
  units        Int      @default(1)
  balanceAfter Int?
  note         String?
  createdAt    DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  GenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([jobId, action])
  @@index([userId, createdAt])
}

model CreditPayment {
  id                 String    @id @default(cuid())
  userId             String
  provider           String    @default("kakaopay")
  productCode        String
  credits            Int
  amountKrw          Int
  status             String    @default("created")
  partnerOrderId     String    @unique
  providerTid        String?   @unique
  providerApprovalId String?
  paymentMethod      String?
  failureReason      String?   @db.Text
  approvedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model CreativeProject {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String?  @db.Text
  status       String   @default("draft")
  aspectRatio  String   @default("9:16")
  canvasWidth  Int      @default(1080)
  canvasHeight Int      @default(1920)
  metadata     Json?
  coverCutId   String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cuts     ProjectCut[]
  assets   ProjectAsset[]
  jobs     GenerationJob[]
  coverCut ProjectCut?     @relation("ProjectCover", fields: [coverCutId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

model SavedProjectBrief {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model ProjectCut {
  id              String   @id @default(cuid())
  projectId       String
  order           Int
  title           String
  durationMs      Int      @default(5000)
  prompt          String   @default("") @db.Text
  negativePrompt  String?  @db.Text
  dialogue        String?  @db.Text
  dialoguePlan    Json?
  speakerPresetId String?
  scene           Json?
  canvas          Json?
  imageUrl        String?
  thumbnailUrl    String?
  videoUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project  CreativeProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs     GenerationJob[]
  coverFor CreativeProject? @relation("ProjectCover")

  @@unique([projectId, order])
  @@index([projectId, updatedAt])
}

model ProjectAsset {
  id           String   @id @default(cuid())
  projectId    String
  jobId        String?
  kind         String
  name         String
  blobUrl      String
  thumbnailUrl String?
  mimeType     String
  metadata     Json?
  createdAt    DateTime @default(now())

  project CreativeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job     GenerationJob?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([jobId])
}

model BoardPost {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  imageIds  String[] // GeneratedImage ID 참조
  links     String[] // 외부 URL
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id])
  comments BoardComment[]
  likes    BoardLike[]

  @@index([userId, createdAt])
  @@index([pinned, createdAt])
}

model BoardComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  post  BoardPost   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id])
  likes BoardLike[]

  @@index([postId, createdAt])
}

model BoardLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id])
  post    BoardPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment BoardComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId, createdAt])
  @@index([commentId, createdAt])
}

model ChatKnowledge {
  id        String   @id @default(cuid())
  category  String // "guide" | "faq" | "persona" | "custom"
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpRequest {
  id        String   @id @default(cuid())
  userId    String
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model GeneratedImage {
  id           String   @id @default(cuid())
  requestId    String
  blobUrl      String // Vercel Blob URL
  thumbnailUrl String?
  mimeType     String   @default("image/png")
  favorite     Boolean  @default(false)
  createdAt    DateTime @default(now())

  request  GenerationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  tagLinks ImageTagLink[]

  @@index([requestId])
}

model ImageTag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("#3b82f6")

  user   User           @relation(fields: [userId], references: [id])
  images ImageTagLink[]

  @@unique([userId, name])
}

model ImageTagLink {
  id      String @id @default(cuid())
  imageId String
  tagId   String

  image GeneratedImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  tag   ImageTag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([imageId, tagId])
}

model Content {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("새 콘텐츠")
  comment   String        @default("")
  updatedAt DateTime      @updatedAt
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id])
  slots     ContentSlot[]

  @@index([userId, updatedAt])
}

model ContentSlot {
  id        String  @id @default(cuid())
  contentId String
  imageId   String
  order     Int
  content   Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, order])
}

model PromptPreset {
  id        String   @id @default(cuid())
  userId    String
  text      String
  usedAt    DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, usedAt])
}

model InstagramAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  igUserId       String
  accessToken    String
  tokenExpiresAt DateTime
  username       String?
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id])
  posts InstagramPost[]
}

model InstagramPost {
  id                String    @id @default(cuid())
  accountId         String
  igMediaId         String
  imageId           String?
  caption           String?
  permalink         String?
  publishedAt       DateTime
  impressions       Int       @default(0)
  reach             Int       @default(0)
  likes             Int       @default(0)
  comments          Int       @default(0)
  saves             Int       @default(0)
  shares            Int       @default(0)
  insightsUpdatedAt DateTime?

  account InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, publishedAt])
}
