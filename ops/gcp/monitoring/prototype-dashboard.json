{
  "displayName": "WonyBananaBot Prototype Operations",
  "gridLayout": {
    "columns": 2,
    "widgets": [
      {
        "title": "Cloud Run request rate",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/request_count\" AND resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_RATE",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              },
              "plotType": "LINE",
              "targetAxis": "Y1"
            }
          ],
          "yAxis": {
            "label": "requests/s",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Cloud Run p95 latency",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/request_latencies\" AND resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_PERCENTILE_95",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "targetAxis": "Y1"
            }
          ],
          "yAxis": {
            "label": "ms",
            "scale": "LOG10"
          }
        }
      },
      {
        "title": "Cloud Run active instances",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/instance_count\" AND resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\" AND metric.labels.state=\"active\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              },
              "plotType": "STACKED_AREA",
              "targetAxis": "Y1"
            }
          ],
          "thresholds": [
            {
              "value": 4,
              "label": "configured max"
            }
          ],
          "yAxis": {
            "label": "instances",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Cloud Run CPU and memory p95",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/cpu/utilizations\" AND resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_PERCENTILE_95",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "CPU p95",
              "targetAxis": "Y1"
            },
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/memory/utilizations\" AND resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_PERCENTILE_95",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Memory p95",
              "targetAxis": "Y1"
            }
          ],
          "yAxis": {
            "label": "utilization",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Cloud SQL connections",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudsql.googleapis.com/database/postgresql/num_backends\" AND resource.type=\"cloudsql_database\" AND resource.labels.database_id=\"wonybananabot:wony-postgres\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "targetAxis": "Y1"
            }
          ],
          "thresholds": [
            {
              "value": 20,
              "label": "investigate"
            }
          ],
          "yAxis": {
            "label": "connections",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Cloud SQL CPU and memory",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudsql.googleapis.com/database/cpu/utilization\" AND resource.type=\"cloudsql_database\" AND resource.labels.database_id=\"wonybananabot:wony-postgres\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MEAN",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "CPU",
              "targetAxis": "Y1"
            },
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudsql.googleapis.com/database/memory/utilization\" AND resource.type=\"cloudsql_database\" AND resource.labels.database_id=\"wonybananabot:wony-postgres\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MEAN",
                    "crossSeriesReducer": "REDUCE_MAX"
                  }
                }
              },
              "plotType": "LINE",
              "legendTemplate": "Memory",
              "targetAxis": "Y1"
            }
          ],
          "yAxis": {
            "label": "utilization",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Cloud Tasks queue depth",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudtasks.googleapis.com/queue/depth\" AND resource.type=\"cloud_tasks_queue\" AND resource.labels.queue_id=\"wony-jobs\"",
                  "aggregation": {
                    "alignmentPeriod": "60s",
                    "perSeriesAligner": "ALIGN_MAX",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              },
              "plotType": "STACKED_AREA",
              "targetAxis": "Y1"
            }
          ],
          "yAxis": {
            "label": "tasks",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Cloud Tasks failed attempts",
        "xyChart": {
          "dataSets": [
            {
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"cloudtasks.googleapis.com/queue/task_attempt_count\" AND resource.type=\"cloud_tasks_queue\" AND resource.labels.queue_id=\"wony-jobs\" AND metric.labels.response_code!=\"ok\"",
                  "aggregation": {
                    "alignmentPeriod": "300s",
                    "perSeriesAligner": "ALIGN_SUM",
                    "crossSeriesReducer": "REDUCE_SUM"
                  }
                }
              },
              "plotType": "STACKED_BAR",
              "targetAxis": "Y1"
            }
          ],
          "yAxis": {
            "label": "attempts/5m",
            "scale": "LINEAR"
          }
        }
      },
      {
        "title": "Generation structured logs",
        "logsPanel": {
          "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\" AND jsonPayload.component=\"wonybananabot\" AND jsonPayload.event=~\"^generation\\.\""
        }
      }
    ]
  }
}
