{
  "displayName": "Wony Prototype - Cloud Run 5xx",
  "combiner": "OR",
  "enabled": true,
  "conditions": [
    {
      "displayName": "Three or more 5xx responses in five minutes",
      "conditionThreshold": {
        "filter": "resource.type=\"cloud_run_revision\" AND resource.labels.service_name=\"wonybananabot\" AND metric.type=\"run.googleapis.com/request_count\" AND metric.labels.response_code_class=\"5xx\"",
        "comparison": "COMPARISON_GT",
        "thresholdValue": 2,
        "duration": "0s",
        "aggregations": [
          {
            "alignmentPeriod": "300s",
            "perSeriesAligner": "ALIGN_SUM",
            "crossSeriesReducer": "REDUCE_SUM"
          }
        ],
        "trigger": {
          "count": 1
        }
      }
    }
  ],
  "documentation": {
    "content": "Cloud Run returned at least three server errors in five minutes. Check the prototype operations dashboard and revision logs.",
    "mimeType": "text/markdown"
  },
  "userLabels": {
    "environment": "prototype",
    "managed_by": "repository"
  }
}
