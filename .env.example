DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/autocartoon"
# Required at runtime. Use a random value with at least 32 characters.
SESSION_SECRET=""
# Required only when db:seed needs to create an administrator.
# Use 16-72 bytes with upper, lower, number, and symbol characters.
SEED_ADMIN_PASSWORD=""
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_API_KEY_FALLBACK="your-fallback-gemini-api-key-here"
