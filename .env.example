DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/autocartoon"
# Required at runtime. Use a random value with at least 32 characters.
SESSION_SECRET=""
# Required only when db:seed needs to create an administrator.
# Use 16-72 bytes with upper, lower, number, and symbol characters.
SEED_ADMIN_PASSWORD=""
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_API_KEY_FALLBACK="your-fallback-gemini-api-key-here"

# Platform-owned Vertex AI (recommended for production; never exposed to users)
PLATFORM_AI_PROVIDER="vertex"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="global"
GOOGLE_CLOUD_VIDEO_LOCATION="us-central1"
# Local/emergency fallback only. Production should use keyless OIDC below.
# Never commit a service account JSON value.
GOOGLE_SERVICE_ACCOUNT_JSON=""
# Keyless Vercel OIDC federation (recommended instead of service account JSON)
GCP_PROJECT_NUMBER=""
GCP_SERVICE_ACCOUNT_EMAIL=""
GCP_WORKLOAD_IDENTITY_POOL_ID=""
GCP_WORKLOAD_IDENTITY_POOL_PROVIDER_ID=""
VERTEX_TEXT_MODEL="gemini-3.1-flash-lite-preview"
VERTEX_IMAGE_MODEL="gemini-3.1-flash-image-preview"
VERTEX_VIDEO_MODEL="veo-3.1-fast-generate-001"
# Veo on Vertex writes output to Cloud Storage, for example gs://bucket/veo.
VERTEX_VIDEO_OUTPUT_GCS_URI=""
# Required for temporary-password delivery.
RESEND_API_KEY=""
# Use a verified Resend sender in production. Defaults to onboarding@resend.dev.
PASSWORD_EMAIL_FROM="워니바나나봇 <account@example.com>"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
