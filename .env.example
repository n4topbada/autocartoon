DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/autocartoon"
PRISMA_CONNECTION_LIMIT="5"
PRISMA_POOL_TIMEOUT="30"
# Required at runtime. Use a random value with at least 32 characters.
SESSION_SECRET=""
# Required only when db:seed needs to create an administrator.
# Use 16-72 bytes with upper, lower, number, and symbol characters.
SEED_ADMIN_PASSWORD=""
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_API_KEY_FALLBACK="your-fallback-gemini-api-key-here"

# Platform-owned Vertex AI (recommended for production; never exposed to users)
PLATFORM_AI_PROVIDER="vertex"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="global"
GOOGLE_CLOUD_VIDEO_LOCATION="us-central1"
# 로컬/비상 폴백 전용. Cloud Run에서는 ADC(Application Default Credentials)가 자동 적용되므로 불필요.
# 서비스 계정 JSON 값은 절대 커밋하지 말 것.
GOOGLE_SERVICE_ACCOUNT_JSON=""

# ── GCP 단일 플랫폼 (Cloud Run) ──
# GCS_BUCKET을 설정하면 비공개 GCS 버킷 + 미디어 게이트웨이(/api/media)를 사용한다.
# 미설정이면 로컬 파일시스템(public/uploads) 폴백으로 동작한다(개발용).
GCS_BUCKET="wonybananabot-media"
# 비동기 job 백엔드. CLOUD_RUN_BASE_URL + TASKS_AUTH_TOKEN + GOOGLE_CLOUD_PROJECT이 모두 있으면
# Cloud Tasks로 재큐(운영), 아니면 같은 프로세스에서 인라인 실행(로컬).
# Cloud Tasks가 붙인 요청을 검증하는 공유 토큰(랜덤 32자 이상).
TASKS_AUTH_TOKEN=""
CLOUD_TASKS_LOCATION="asia-northeast3"
CLOUD_TASKS_QUEUE="wony-jobs"
# Cloud Run 서비스가 Cloud Tasks 대상으로 호출할 자기 자신의 공개 URL.
CLOUD_RUN_BASE_URL=""
# 컨테이너 빌드 시 standalone 출력을 켠다(Dockerfile에서 설정).
# BUILD_TARGET="cloudrun"
VERTEX_TEXT_MODEL="gemini-3.1-flash-lite"
VERTEX_IMAGE_MODEL="gemini-3.1-flash-image"
VERTEX_VIDEO_MODEL="veo-3.1-fast-generate-001"
# Veo on Vertex writes output to Cloud Storage, for example gs://bucket/veo.
VERTEX_VIDEO_OUTPUT_GCS_URI=""
# Required for temporary-password delivery.
RESEND_API_KEY=""
# Use a verified Resend sender in production. Defaults to onboarding@resend.dev.
PASSWORD_EMAIL_FROM="워니바나나봇 <account@example.com>"
# Server-side canonical public origin. Set this on Cloud Run and update it when the custom domain changes.
APP_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Kakao Login. Register both local and production callback URLs in Kakao Developers.
KAKAO_REST_API_KEY=""
KAKAO_CLIENT_SECRET=""

# KakaoPay Online Payment. TC0ONETIME is the official test CID only.
KAKAOPAY_SECRET_KEY=""
KAKAOPAY_CID="TC0ONETIME"
